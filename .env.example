# Copy to .env for local development (never commit the real .env file).
# In prod, these are injected by the firm's secret manager / container
# orchestrator, NOT read from a file — see configs/prod.yaml for the
# ${VAR_NAME} references that pull these in at runtime.

SECFI_DB_HOST=localhost
SECFI_DB_USER=secfi_dev
SECFI_DB_PASSWORD=dev_local_only_not_a_real_secret
SECFI_INTERNAL_GATEWAY_ORIGIN=http://localhost:3000

# Vendor API credentials (prod only — leave unset in dev, file-based
# connectors are used instead, see configs/base.yaml `ingestion.sources`)
EQUILEND_API_BASE_URL=
EQUILEND_API_KEY=
DATALEND_API_BASE_URL=
DATALEND_API_KEY=
